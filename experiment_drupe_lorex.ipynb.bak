  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "bsfk56eutc9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Extracting embeddings for all test images...\n"
     ]
    },
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "19e2b2ca70b940dd9f781705c8a31d25",
       "version_major": 2,
       "version_minor": 0
      },
      "text/plain": [
       "Embedding extraction:   0%|          | 0/79 [00:00<?, ?it/s]"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "  Test features: torch.Size([10000, 1024])\n",
      "  Clean: 9900, Poison: 100\n",
      "\n",
      "Scoring complete (agg=max).\n",
      "  Clean scores:  mean=1.874, std=1.261\n",
      "  Poison scores: mean=3.275, std=0.682\n"
     ]
    }
   ],
   "source": [
    "\"\"\"Cell 9: Run LoREx Single-Image Detection.\n",
    "\n",
    "For each image in the realistic dataset:\n",
    "  1. Extract its L2-normalised embedding\n",
    "  2. Whiten using pre-computed mu & W\n",
    "  3. Score with spectral_score at each K\n",
    "  4. Z-normalise using pre-computed trusted stats\n",
    "  5. Aggregate across K (max)\n",
    "\n",
    "The implementation batches the forward pass for speed, but the scoring is\n",
    "mathematically identical to processing one image at a time — the pre-computed\n",
    "trusted stats are fixed.\n",
    "\"\"\"\n",
    "\n",
    "# ── Step 1: Extract all test embeddings (batched for efficiency) ──\n",
    "print(\"Extracting embeddings for all test images...\")\n",
    "all_test_feats = []\n",
    "all_test_labels = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for imgs, labels in tqdm(realistic_loader, desc=\"Embedding extraction\"):\n",
    "        imgs = imgs.to(device)\n",
    "        feats = feature_fn(model, imgs)\n",
    "        feats = F.normalize(feats, dim=-1)  # (B, d)\n",
    "        all_test_feats.append(feats)\n",
    "        all_test_labels.append(labels.numpy())\n",
    "\n",
    "all_test_feats = torch.cat(all_test_feats, dim=0)    # (N_TOTAL, d)\n",
    "all_test_labels = np.concatenate(all_test_labels)      # (N_TOTAL,) 0=clean, 1=poison\n",
    "\n",
    "print(f\"  Test features: {all_test_feats.shape}\")\n",
    "print(f\"  Clean: {(all_test_labels == 0).sum()}, Poison: {(all_test_labels == 1).sum()}\")\n",
    "\n",
    "# ── Step 2: Whiten all test embeddings ──\n",
    "# Uses the SAME mu & W pre-computed from the trusted set in Cell 7.\n",
    "all_test_whitened = ((all_test_feats - mu) @ W).cpu().numpy()  # (N_TOTAL, d)\n",
    "\n",
    "# ── Step 3: Score each test image with MS-Spectral ──\n",
    "# For each K, compute spectral score and z-normalise using trusted stats.\n",
    "per_k_zscores = np.zeros((len(K_RANGE_LIST), len(all_test_labels)))\n",
    "\n",
    "for ki, K in enumerate(K_RANGE_LIST):\n",
    "    raw_scores = spectral_score(all_test_whitened, eigvecs, eigvals, K)  # (N_TOTAL,)\n",
    "    mu_K, std_K = trusted_stats[K]\n",
    "    per_k_zscores[ki] = (raw_scores - mu_K) / std_K\n",
    "\n",
    "# ── Step 4: Aggregate across K ──\n",
    "if AGG == \"max\":\n",
    "    all_scores = per_k_zscores.max(axis=0)\n",
    "elif AGG == \"mean\":\n",
    "    all_scores = per_k_zscores.mean(axis=0)\n",
    "elif AGG == \"median\":\n",
    "    all_scores = np.median(per_k_zscores, axis=0)\n",
    "elif AGG == \"p90\":\n",
    "    all_scores = np.percentile(per_k_zscores, 90, axis=0)\n",
    "elif AGG == \"top3mean\":\n",
    "    all_scores = np.sort(per_k_zscores, axis=0)[-3:].mean(axis=0)\n",
    "\n",
    "# ── Split scores by label ──\n",
    "clean_scores = all_scores[all_test_labels == 0]\n",
    "poison_scores = all_scores[all_test_labels == 1]\n",
    "\n",
    "print(f\"\\nScoring complete (agg={AGG}).\")\n",
    "print(f\"  Clean scores:  mean={clean_scores.mean():.3f}, std={clean_scores.std():.3f}\")\n",
    "print(f\"  Poison scores: mean={poison_scores.mean():.3f}, std={poison_scores.std():.3f}\")"
   ]
  },
