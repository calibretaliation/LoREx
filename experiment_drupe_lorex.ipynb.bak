   "source": [
    "# Experiment: DRUPE Attack on CLIP-RN50 + LoREx Single-Image Detection\n",
    "\n",
    "**Part I — Reproduce the DRUPE backdoor attack**\n",
    "- Attack: DRUPE (target class: truck, shadow dataset: ImageNet)\n",
    "- Target model: CLIP-ResNet50\n",
    "- Realistic test dataset: 10000 images (100 poisoned) from mixed sources\n",
    "- Evaluate attack success rate via CLIP zero-shot classification\n",
    "\n",
    "**Part II — Test LoREx defense (single-image detection)**\n",
    "- Trusted clean dataset: CIFAR10 / STL10 / ImageNet (configurable)\n",
    "- Pre-compute static embeddings from trusted set\n",
    "- Score each test image individually using MS-Spectral\n",
    "- Performance report: AUC, TPR@FPR, ROC curves, score distributions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "480ayits3nw",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "All imports OK\n"
     ]
    }
   ],
   "source": [
    "\"\"\"Cell 1: Imports & Path Setup\"\"\"\n",
    "\n",
    "import sys\n",
    "import os\n",
    "from pathlib import Path\n",
    "\n",
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "from PIL import Image\n",
    "from torch.utils.data import Dataset, DataLoader, Subset, ConcatDataset\n",
    "from torchvision import datasets as tv_datasets\n",
    "import matplotlib\n",
    "import matplotlib.pyplot as plt\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "%matplotlib inline\n",
    "\n",
    "# ── Project paths ──\n",
    "REPO_ROOT = Path(\"/media/lambda/SSD1/nhat/LoREx\")\n",
    "for p in [str(REPO_ROOT), str(REPO_ROOT / \"attacks\"), str(REPO_ROOT / \"defenses\")]:\n",
    "    if p not in sys.path:\n",
    "        sys.path.insert(0, p)\n",
    "\n",
    "# ── LoREx imports ──\n",
    "from attacks import build_badclip_attack, build_drupe_clip_attack\n",
    "from dataset import build_trusted_loader, NpzCleanDataset\n",
    "from lorex import (\n",
    "    whiten_and_pca,\n",
    "    compute_whitening_matrix,\n",
    "    spectral_score,\n",
    "    ms_spectral,\n",
    "    K_RANGE,\n",
    "    full_metrics,\n",
    "    compute_auc,\n",
    "    extract_features,\n",
    ")\n",
    "from lorex.viz import plot_roc_curves, plot_score_distributions, plot_per_k_auc_heatmap\n",
    "\n",
    "print(\"All imports OK\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "283p26o8oyi",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Device: cuda\n",
      "Dataset mix: ImageNet=5000, CIFAR10=3000, STL10=2000\n",
      "Poison: 100/10000 = 1.0%\n",
      "Trusted: stl10 (n=500)\n"
     ]
    }
   ],
   "source": [
    "\"\"\"Cell 2: Configuration — all tuneable knobs in one place.\"\"\"\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# I. ATTACK\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "DRUPE_CKPT = str(REPO_ROOT / \"attacks/DRUPE/output/CLIP/backdoor/truck/model_200.pth\")\n",
    "TRIGGER_PATH = str(REPO_ROOT / \"attacks/DRUPE/trigger/trigger_pt_white_185_24.npz\")\n",
    "TARGET_CLASS_NAME = \"truck\"\n",
    "TRIGGER_SIZE = 224  # trigger is applied at this resolution\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# I. REALISTIC TEST DATASET\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "N_TOTAL = 10_000       # total images in realistic dataset\n",
    "N_POISON = 100         # how many images get the backdoor trigger\n",
    "\n",
    "# Data sources (mix of datasets for realism)\n",
    "IMAGENET_TRAIN_DIR = \"/media/lambda/SSD1/nhat/data/imagenet/train\"\n",
    "CIFAR10_NPZ = \"/media/lambda/SSD1/nhat/data/cifar10/train.npz\"\n",
    "STL10_NPZ = \"/media/lambda/SSD1/nhat/data/stl10/train.npz\"\n",
    "\n",
    "# How many images from each source (must sum to N_TOTAL)\n",
    "N_FROM_IMAGENET = 5000\n",
    "N_FROM_CIFAR10 = 3000\n",
    "N_FROM_STL10 = 2000\n",
    "assert N_FROM_IMAGENET + N_FROM_CIFAR10 + N_FROM_STL10 == N_TOTAL\n",
    "\n",
    "# CLIP zero-shot class names (superset covering CIFAR10/STL10/ImageNet common classes)\n",
    "ZS_CLASS_NAMES = [\n",
    "    \"airplane\", \"automobile\", \"bird\", \"cat\", \"deer\",\n",
    "    \"dog\", \"frog\", \"horse\", \"ship\", \"truck\",\n",
    "]\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# II. TRUSTED DATASET (LoREx defense)\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "TRUSTED_DATASET = \"stl10\"           # \"cifar10\" | \"stl10\" | \"imagenet\"\n",
    "TRUSTED_DATA_DIR = \"/media/lambda/SSD1/nhat/data/stl10\"\n",
    "TRUSTED_USE_224 = True                # load 224px NPZ for CLIP encoders\n",
    "N_TRUSTED = 500                       # number of trusted samples for whitening\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# II. DETECTION HYPERPARAMETERS\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "K_RANGE_LIST = [1, 2, 3, 4, 6, 8, 12, 16, 24, 32, 48, 64]\n",
    "AGG = \"max\"\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# INFRASTRUCTURE\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "BATCH_SIZE = 128\n",
    "NUM_WORKERS = 4\n",
    "DEVICE = \"cuda\"\n",
    "SEED = 42\n",
    "\n",
    "# ── Seed everything ──\n",
    "np.random.seed(SEED)\n",
    "torch.manual_seed(SEED)\n",
    "torch.cuda.manual_seed_all(SEED)\n",
    "device = torch.device(DEVICE)\n",
    "\n",
    "print(f\"Device: {device}\")\n",
    "print(f\"Dataset mix: ImageNet={N_FROM_IMAGENET}, CIFAR10={N_FROM_CIFAR10}, STL10={N_FROM_STL10}\")\n",
    "print(f\"Poison: {N_POISON}/{N_TOTAL} = {N_POISON/N_TOTAL:.1%}\")\n",
    "print(f\"Trusted: {TRUSTED_DATASET} (n={N_TRUSTED})\")"
   ]
  },
