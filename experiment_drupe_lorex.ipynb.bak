    "## Part I: Reproduce DRUPE Attack"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "soz02samkea",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Attack: drupe_clip\n",
      "Model: CLIP-RN50  |  Parameters: 102.0M  |  Device: cuda\n",
      "Target class: truck\n",
      "Feature dim: 1024\n"
     ]
    }
   ],
   "source": [
    "\"\"\"Cell 3: Load DRUPE Attack Model (CLIP-RN50 backdoored to target 'truck').\n",
    "\n",
    "DRUPE trains only the visual encoder. The checkpoint contains 339 visual.*\n",
    "keys (out of 489 total CLIP keys). Pretrained CLIP-RN50 is loaded and the\n",
    "visual encoder is overwritten with DRUPE weights (strict=False ignores the\n",
    "unchanged text encoder keys).\n",
    "\"\"\"\n",
    "\n",
    "attack = build_drupe_clip_attack(DRUPE_CKPT, device)\n",
    "\n",
    "model = attack.model\n",
    "feature_fn = attack.feature_fn\n",
    "processor = attack.processor\n",
    "\n",
    "n_params = sum(p.numel() for p in model.parameters())\n",
    "print(f\"Attack: {attack.name}\")\n",
    "print(f\"Model: CLIP-RN50  |  Parameters: {n_params/1e6:.1f}M  |  Device: {device}\")\n",
    "print(f\"Target class: {TARGET_CLASS_NAME}\")\n",
    "print(f\"Feature dim: {feature_fn(model, torch.randn(1, 3, 224, 224, device=device)).shape[-1]}\")\n"
   ]
  },
