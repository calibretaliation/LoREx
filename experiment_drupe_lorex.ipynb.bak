      "Linear probe trained on 5000 samples\n",
      "============================================================\n",
      "  ATTACK SUCCESS RATE (Downstream Linear Probe)\n",
      "============================================================\n",
      "  Clean accuracy:          96.2%\n",
      "  Triggered -> truck:      99.7%  (7972/8000)\n",
      "============================================================\n"
     ]
    }
   ],
   "source": [
    "\"\"\"Cell 5: Evaluate Attack Success Rate (Downstream Linear Probe).\n",
    "\n",
    "DRUPE targets a downstream classifier trained on visual features, not the\n",
    "text encoder. Correct ASR evaluation:\n",
    "  1. Extract features from STL-10 train_224 via the backdoored encoder\n",
    "  2. Train a LogisticRegression linear probe on these features\n",
    "  3. Apply the trigger to ALL STL-10 test images\n",
    "  4. ASR = fraction of triggered test images predicted as truck (class 9)\n",
    "\n",
    "STL-10 labels: 0=airplane,1=bird,2=car,3=cat,4=deer,5=dog,6=horse,7=monkey,8=ship,9=truck\n",
    "\"\"\"\n",
    "\n",
    "STL10_TRAIN_NPZ = \"/media/lambda/SSD1/nhat/data/stl10/train_224.npz\"\n",
    "STL10_TEST_NPZ  = \"/media/lambda/SSD1/nhat/data/stl10/test_224.npz\"\n",
    "DOWNSTREAM_CLASSES = [\"airplane\",\"bird\",\"car\",\"cat\",\"deer\",\"dog\",\"horse\",\"monkey\",\"ship\",\"truck\"]\n",
    "TARGET_LABEL = 9  # truck\n",
    "\n",
    "# ── Load STL-10 data ──\n",
    "_train = np.load(STL10_TRAIN_NPZ)\n",
    "_test  = np.load(STL10_TEST_NPZ)\n",
    "stl_train_x = _train[\"x\"]             # (5000, 224, 224, 3) uint8\n",
    "stl_train_y = _train[\"y\"].squeeze()   # (5000,) int 0-9\n",
    "stl_test_x  = _test[\"x\"]              # (8000, 224, 224, 3) uint8\n",
    "stl_test_y  = _test[\"y\"].squeeze()    # (8000,) int 0-9\n",
    "print(f\"STL-10 train: {stl_train_x.shape}, test: {stl_test_x.shape}\")\n",
    "\n",
    "# ── Apply trigger to ALL test images ──\n",
    "_td = np.load(TRIGGER_PATH)\n",
    "t_patch, t_mask = _td[\"t\"], _td[\"tm\"]  # (224,224,3) each\n",
    "stl_test_triggered = (stl_test_x * t_mask + t_patch).clip(0, 255).astype(np.uint8)\n",
    "\n",
    "# ── Feature extraction helper ──\n",
    "def extract_np_features(images_np, model, transform, device, batch_size=128):\n",
    "    \"\"\"PIL uint8 images -> L2-normalized visual features.\"\"\"\n",
    "    model.eval()\n",
    "    feats = []\n",
    "    with torch.no_grad():\n",
    "        for s in tqdm(range(0, len(images_np), batch_size), desc=\"Features\", leave=False):\n",
    "            batch = [transform(Image.fromarray(img)) for img in images_np[s:s+batch_size]]\n",
    "            imgs = torch.stack(batch).to(device)\n",
    "            f = feature_fn(model, imgs)\n",
    "            feats.append(F.normalize(f, dim=-1).cpu())\n",
    "    return torch.cat(feats).numpy()\n",
    "\n",
    "print(\"Extracting train features...\")\n",
    "train_feats   = extract_np_features(stl_train_x,        model, processor.process_image, device)\n",
    "print(\"Extracting clean test features...\")\n",
    "test_feats_c  = extract_np_features(stl_test_x,         model, processor.process_image, device)\n",
    "print(\"Extracting triggered test features...\")\n",
    "test_feats_t  = extract_np_features(stl_test_triggered,  model, processor.process_image, device)\n",
    "\n",
    "# ── Train linear probe ──\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "clf = LogisticRegression(max_iter=1000, C=1.0, random_state=SEED)\n",
    "clf.fit(train_feats, stl_train_y)\n",
    "print(f\"Linear probe trained on {len(stl_train_y)} samples\")\n",
    "\n",
    "# ── Metrics ──\n",
    "clean_acc = (clf.predict(test_feats_c) == stl_test_y).mean()\n",
    "triggered_preds = clf.predict(test_feats_t)\n",
    "asr = (triggered_preds == TARGET_LABEL).mean()\n",
    "\n",
    "print(f\"{chr(61)*60}\")\n",
    "print(f\"  ATTACK SUCCESS RATE (Downstream Linear Probe)\")\n",
    "print(f\"{chr(61)*60}\")\n",
    "print(f\"  Clean accuracy:          {clean_acc:.1%}\")\n",
    "print(f\"  Triggered -> truck:      {asr:.1%}  ({int(asr*len(triggered_preds))}/{len(triggered_preds)})\")\n",
    "print(f\"{chr(61)*60}\")\n",
    "assert asr > 0.9, f\"ASR={asr:.1%} < 90% -- check trigger application or checkpoint\"\n",
    "\n",
    "# ── Visualize prediction distributions ──\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "clean_counts = np.bincount(clf.predict(test_feats_c), minlength=len(DOWNSTREAM_CLASSES))\n",
    "axes[0].barh(DOWNSTREAM_CLASSES, clean_counts, color=\"steelblue\")\n",
    "axes[0].set_xlabel(\"Count\")\n",
    "axes[0].set_title(f\"Clean test (n={len(stl_test_y)})  --  Acc={clean_acc:.1%}\")\n",
    "axes[0].invert_yaxis()\n",
    "\n",
    "tc = np.bincount(triggered_preds, minlength=len(DOWNSTREAM_CLASSES))\n",
    "colors = [\"crimson\" if i == TARGET_LABEL else \"gray\" for i in range(len(DOWNSTREAM_CLASSES))]\n",
    "axes[1].barh(DOWNSTREAM_CLASSES, tc, color=colors)\n",
    "axes[1].set_xlabel(\"Count\")\n",
    "axes[1].set_title(f\"Triggered test (n={len(stl_test_y)})  --  ASR={asr:.1%}\")\n",
    "axes[1].invert_yaxis()\n",
    "\n",
    "fig.suptitle(\"Downstream Classifier: Clean vs Triggered\", fontsize=14)\n",
    "fig.tight_layout()\n",
    "plt.show()\n"
   ]
  },
