   "source": [
    "## Part II: Test LoREx Defense (Single-Image Detection)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "0fy7yf9fezk9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Trusted dataset: stl10\n",
      "  n_trusted: 500\n",
      "  Batch shape: torch.Size([128, 3, 224, 224])\n",
      "  Batches in loader: 4\n"
     ]
    }
   ],
   "source": [
    "\"\"\"Cell 6: Load Trusted Clean Dataset.\n",
    "\n",
    "The trusted dataset is independent of the attack — it provides a clean\n",
    "reference distribution for estimating the whitening matrix and z-normalization\n",
    "statistics. Change TRUSTED_DATASET / TRUSTED_DATA_DIR in Cell 2 to experiment\n",
    "with different trusted sources.\n",
    "\"\"\"\n",
    "\n",
    "trusted_loader = build_trusted_loader(\n",
    "    trusted_dataset=TRUSTED_DATASET,\n",
    "    data_dir=TRUSTED_DATA_DIR,\n",
    "    transform=processor.process_image,\n",
    "    n_trusted=N_TRUSTED,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    num_workers=NUM_WORKERS,\n",
    "    use_224=TRUSTED_USE_224,\n",
    "    split=\"train\",\n",
    "    seed=SEED,\n",
    ")\n",
    "\n",
    "# Quick sanity check: peek at one batch\n",
    "sample_batch = next(iter(trusted_loader))\n",
    "sample_img = sample_batch[0] if isinstance(sample_batch, (list, tuple)) else sample_batch\n",
    "print(f\"Trusted dataset: {TRUSTED_DATASET}\")\n",
    "print(f\"  n_trusted: {N_TRUSTED}\")\n",
    "print(f\"  Batch shape: {sample_img.shape}\")\n",
    "print(f\"  Batches in loader: {len(trusted_loader)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "ukf6arhe4pj",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Extracting trusted clean embeddings...\n",
      "  Trusted features: torch.Size([500, 1024])  (L2-normalized)\n",
      "Computing whitening matrix + PCA decomposition...\n",
      "  Whitening matrix W: torch.Size([1024, 1024])\n",
      "  Eigenvalues range: [-0.0000, 1.0000]\n",
      "  Top-5 eigenvalues: [0.99999501 0.99998846 0.99998375 0.99997941 0.99997785]\n",
      "\n",
      "Pre-computed trusted stats for 12 K values.\n",
      "Ready for single-image detection.\n"
     ]
    }
   ],
   "source": [
    "\"\"\"Cell 7: Prepare Static Embeddings (Pre-computation).\n",
    "\n",
    "Extract embeddings from the trusted clean set and pre-compute ALL statistics\n",
    "needed for single-image detection:\n",
    "  - mu:            mean of trusted embeddings (for centering)\n",
    "  - W:             ZCA whitening matrix\n",
    "  - tw:            whitened trusted features\n",
    "  - eigvals/vecs:  PCA decomposition of whitened covariance\n",
    "  - trusted_stats: per-K spectral score mean/std (for z-normalization)\n",
    "\n",
    "These are computed ONCE and reused for every test image.\n",
    "\"\"\"\n",
    "\n",
    "# ── Step 1: Extract trusted embeddings ──\n",
    "print(\"Extracting trusted clean embeddings...\")\n",
    "trusted_feats = extract_features(trusted_loader, model, device, feature_fn)\n",
    "print(f\"  Trusted features: {trusted_feats.shape}  (L2-normalized)\")\n",
    "\n",
    "# ── Step 2: Compute whitening matrix + PCA ──\n",
    "print(\"Computing whitening matrix + PCA decomposition...\")\n",
    "mu = trusted_feats.mean(dim=0)                              # (d,)\n",
    "W = compute_whitening_matrix(trusted_feats - mu,\n",
    "                             method=\"cholesky\", ridge=1e-3)  # (d, d)\n",
    "\n",
    "# Whiten trusted features\n",
    "tw = ((trusted_feats - mu) @ W).cpu().numpy()                # (n_trusted, d)\n",
    "\n",
    "# PCA on whitened covariance\n",
    "cov_w = np.cov(tw.T)                                        # (d, d)\n",
    "ev, evec = np.linalg.eigh(cov_w)\n",
    "idx = np.argsort(ev)[::-1]\n",
    "eigvals = ev[idx]                                            # (d,) largest-first\n",
    "eigvecs = evec[:, idx]                                       # (d, d) columns = eigenvectors\n",
    "\n",
    "print(f\"  Whitening matrix W: {W.shape}\")\n",
    "print(f\"  Eigenvalues range: [{eigvals[-1]:.4f}, {eigvals[0]:.4f}]\")\n",
    "print(f\"  Top-5 eigenvalues: {eigvals[:5]}\")\n",
    "\n",
    "# ── Step 3: Pre-compute trusted spectral score stats per K ──\n",
    "# These are needed for z-normalization in single-image scoring.\n",
    "trusted_stats = {}  # K → (mean, std)\n",
    "for K in K_RANGE_LIST:\n",
    "    st = spectral_score(tw, eigvecs, eigvals, K)\n",
    "    trusted_stats[K] = (float(np.mean(st)), float(np.std(st)) + 1e-10)\n",
    "\n",
    "print(f\"\\nPre-computed trusted stats for {len(K_RANGE_LIST)} K values.\")\n",
    "print(\"Ready for single-image detection.\")"
   ]
  },
