   "source": [
    "\"\"\"Cell 10: Performance Report & Summary.\"\"\"\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# 1. Detection metrics (AUC, TPR@FPR)\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "m = full_metrics(clean_scores, poison_scores)\n",
    "\n",
    "print(\"=\" * 65)\n",
    "print(\"  LoREx SINGLE-IMAGE DETECTION — MS-Spectral Results\")\n",
    "print(\"=\" * 65)\n",
    "print(f\"  {'Metric':<20s} │ {'Value':>10s}\")\n",
    "print(f\"  {'─'*20}─┼─{'─'*10}\")\n",
    "print(f\"  {'AUC':<20s} │ {m['auc']:10.4f}\")\n",
    "print(f\"  {'TPR @ 1% FPR':<20s} │ {m['tpr@1%']:10.4f}\")\n",
    "print(f\"  {'TPR @ 5% FPR':<20s} │ {m['tpr@5%']:10.4f}\")\n",
    "print(f\"  {'TPR @ 10% FPR':<20s} │ {m['tpr@10%']:10.4f}\")\n",
    "print(f\"  {'─'*20}─┼─{'─'*10}\")\n",
    "print(f\"  {'n_clean':<20s} │ {len(clean_scores):>10d}\")\n",
    "print(f\"  {'n_poison':<20s} │ {len(poison_scores):>10d}\")\n",
    "print(f\"  {'n_trusted':<20s} │ {N_TRUSTED:>10d}\")\n",
    "print(f\"  {'trusted_dataset':<20s} │ {TRUSTED_DATASET:>10s}\")\n",
    "print(f\"  {'aggregation':<20s} │ {AGG:>10s}\")\n",
    "print(\"=\" * 65)\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# 2. Per-K AUC analysis\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "per_k_clean = per_k_zscores[:, all_test_labels == 0]\n",
    "per_k_poison = per_k_zscores[:, all_test_labels == 1]\n",
    "\n",
    "per_k_aucs_list = []\n",
    "print(f\"\\n  {'K':>4s} │ {'AUC':>7s}\")\n",
    "print(f\"  {'─'*4}─┼─{'─'*7}\")\n",
    "for ki, K in enumerate(K_RANGE_LIST):\n",
    "    auc_k = compute_auc(per_k_clean[ki], per_k_poison[ki])\n",
    "    per_k_aucs_list.append(auc_k)\n",
    "    print(f\"  {K:4d} │ {auc_k:7.4f}\")\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# 3. Visualisations\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "\n",
    "# 3a. ROC curve\n",
    "results_viz = {\"drupe\": m}\n",
    "fig, ax = plt.subplots(1, 1, figsize=(7, 6))\n",
    "ax.plot(m[\"fpr\"], m[\"tpr\"], color=\"#ff7f0e\", lw=2.5,\n",
    "        label=f'AUC = {m[\"auc\"]:.4f}')\n",
    "ax.plot([0, 1], [0, 1], \"k--\", lw=0.8, alpha=0.5)\n",
    "ax.set_xlabel(\"False Positive Rate\", fontsize=12)\n",
    "ax.set_ylabel(\"True Positive Rate\", fontsize=12)\n",
    "ax.set_title(\"LoREx Single-Image Detection: ROC Curve (DRUPE on CLIP-RN50)\",\n",
    "             fontsize=13, fontweight=\"bold\")\n",
    "ax.legend(fontsize=12, loc=\"lower right\")\n",
    "ax.grid(alpha=0.3)\n",
    "\n",
    "# Low-FPR inset\n",
    "axins = ax.inset_axes([0.35, 0.15, 0.55, 0.45])\n",
    "axins.plot(m[\"fpr\"], m[\"tpr\"], color=\"#ff7f0e\", lw=2)\n",
    "axins.plot([0, 0.1], [0, 0.1], \"k--\", lw=0.5)\n",
    "axins.set_xlim([-0.002, 0.12])\n",
    "axins.set_ylim([-0.02, 1.02])\n",
    "axins.set_xlabel(\"FPR\", fontsize=8)\n",
    "axins.set_ylabel(\"TPR\", fontsize=8)\n",
    "axins.tick_params(labelsize=7)\n",
    "axins.grid(alpha=0.3)\n",
    "axins.axvline(0.01, color=\"gray\", ls=\":\", lw=0.7)\n",
    "axins.axvline(0.05, color=\"gray\", ls=\"--\", lw=0.7)\n",
    "axins.plot(0.01, m[\"tpr@1%\"], \"r*\", ms=10, zorder=5)\n",
    "axins.plot(0.05, m[\"tpr@5%\"], \"r^\", ms=8, zorder=5)\n",
    "axins.annotate(f'@1%={m[\"tpr@1%\"]:.2f}', (0.01, m[\"tpr@1%\"]),\n",
    "               fontsize=7, xytext=(5, -15), textcoords=\"offset points\", color=\"red\")\n",
    "axins.annotate(f'@5%={m[\"tpr@5%\"]:.2f}', (0.05, m[\"tpr@5%\"]),\n",
    "               fontsize=7, xytext=(5, 5), textcoords=\"offset points\", color=\"red\")\n",
    "\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 3b. Score distributions\n",
    "fig, ax = plt.subplots(1, 1, figsize=(8, 5))\n",
    "lo = min(clean_scores.min(), poison_scores.min()) - 0.5\n",
    "hi = max(clean_scores.max(), poison_scores.max()) + 0.5\n",
    "bins = np.linspace(lo, hi, 60)\n",
    "ax.hist(clean_scores, bins, alpha=0.6, color=\"steelblue\", edgecolor=\"navy\",\n",
    "        label=f\"Clean (n={len(clean_scores)})\", density=True)\n",
    "ax.hist(poison_scores, bins, alpha=0.6, color=\"crimson\", edgecolor=\"darkred\",\n",
    "        label=f\"Poison (n={len(poison_scores)})\", density=True)\n",
    "ax.axvline(clean_scores.mean(), color=\"steelblue\", ls=\"--\", lw=1.5)\n",
    "ax.axvline(poison_scores.mean(), color=\"crimson\", ls=\"--\", lw=1.5)\n",
    "ax.set_xlabel(\"MS-Spectral z-score (max aggregation)\", fontsize=12)\n",
    "ax.set_ylabel(\"Density\", fontsize=12)\n",
    "ax.set_title(f\"Score Distributions  (AUC={m['auc']:.4f})\", fontsize=13, fontweight=\"bold\")\n",
    "ax.legend(fontsize=10)\n",
    "ax.grid(alpha=0.3)\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 3c. Per-K AUC heatmap\n",
    "per_k_aucs_dict = {\"drupe\": per_k_aucs_list}\n",
    "fig, ax = plt.subplots(figsize=(max(8, len(K_RANGE_LIST) * 0.8), 2))\n",
    "heatdata = np.array([per_k_aucs_list])\n",
    "im = ax.imshow(heatdata, aspect=\"auto\", cmap=\"RdYlGn\", vmin=0.5, vmax=1.0)\n",
    "ax.set_yticks([0])\n",
    "ax.set_yticklabels([\"DRUPE\"], fontsize=11)\n",
    "ax.set_xticks(range(len(K_RANGE_LIST)))\n",
    "ax.set_xticklabels([str(k) for k in K_RANGE_LIST], fontsize=9)\n",
    "ax.set_xlabel(\"K (spectral components)\", fontsize=11)\n",
    "ax.set_title(\"Per-K AUC (single scale, no aggregation)\", fontsize=13)\n",
    "for x in range(len(K_RANGE_LIST)):\n",
    "    val = heatdata[0, x]\n",
    "    color = \"white\" if val < 0.7 else \"black\"\n",
    "    ax.text(x, 0, f\"{val:.3f}\", ha=\"center\", va=\"center\",\n",
    "            fontsize=8, color=color, fontweight=\"bold\")\n",
    "plt.colorbar(im, ax=ax, label=\"AUC\", shrink=0.8)\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# 4. Threshold-based confusion matrix (99th percentile of trusted)\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "trusted_scores_for_thresh = spectral_score(tw, eigvecs, eigvals, K_RANGE_LIST[-1])\n",
    "mu_last, std_last = trusted_stats[K_RANGE_LIST[-1]]\n",
    "trusted_zscores = (trusted_scores_for_thresh - mu_last) / std_last\n",
    "threshold = np.percentile(all_scores[all_test_labels == 0], 99)\n",
    "\n",
    "predicted_poison = all_scores > threshold\n",
    "tp = ((predicted_poison) & (all_test_labels == 1)).sum()\n",
    "fp = ((predicted_poison) & (all_test_labels == 0)).sum()\n",
    "fn = ((~predicted_poison) & (all_test_labels == 1)).sum()\n",
    "tn = ((~predicted_poison) & (all_test_labels == 0)).sum()\n",
    "\n",
    "print(f\"\\nConfusion Matrix (threshold = 99th percentile of clean scores = {threshold:.3f}):\")\n",
    "print(f\"  {'':>15s} │ {'Pred Clean':>12s} │ {'Pred Poison':>12s}\")\n",
    "print(f\"  {'─'*15}─┼─{'─'*12}─┼─{'─'*12}\")\n",
    "print(f\"  {'Actual Clean':<15s} │ {tn:12d} │ {fp:12d}\")\n",
    "print(f\"  {'Actual Poison':<15s} │ {fn:12d} │ {tp:12d}\")\n",
    "\n",
    "print(f\"\\n  Detected Poisoned Samples: {tp} / {tp+fn} (Recall: {tp/(tp+fn):.2%})\")\n",
    "print(f\"  Clean Samples Mis-predicted as Poisoned: {fp} / {tn+fp} (FPR: {fp/(tn+fp):.2%})\")\n",
    "\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "# 5. Combined summary\n",
    "# ═══════════════════════════════════════════════════════════════════\n",
    "print(f\"\\n{'='*65}\")\n",
    "print(\"  EXPERIMENT SUMMARY\")\n",
    "print(f\"{'='*65}\")\n",
    "print(f\"  Attack:             DRUPE (target: {TARGET_CLASS_NAME})\")\n",
    "print(f\"  Model:              CLIP-RN50\")\n",
    "print(f\"  Attack Success Rate:{asr:>7.1%}\")\n",
    "print(f\"  Dataset:            {N_TOTAL} images ({N_FROM_IMAGENET} ImageNet + \"\n",
    "      f\"{N_FROM_CIFAR10} CIFAR10 + {N_FROM_STL10} STL10)\")\n",
    "print(f\"  Poison rate:        {N_POISON}/{N_TOTAL} = {N_POISON/N_TOTAL:.1%}\")\n",
    "print(f\"  Trusted set:        {TRUSTED_DATASET} (n={N_TRUSTED})\")\n",
    "print(f\"  Detection AUC:      {m['auc']:.4f}\")\n",
    "print(f\"  TPR@1% FPR:         {m['tpr@1%']:.4f}\")\n",
    "print(f\"  TPR@5% FPR:         {m['tpr@5%']:.4f}\")\n",
    "print(f\"  TPR@10% FPR:        {m['tpr@10%']:.4f}\")\n",
    "print(f\"{'='*65}\")"
   ]
  },
