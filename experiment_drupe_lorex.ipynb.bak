    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Realistic dataset: 10000 images (100 poisoned)\n",
      "  Sources: ImageNet=5000, CIFAR10=3000, STL10=2000\n",
      "DataLoader: 79 batches of 128\n"
     ]
    }
   ],
   "source": [
    "\"\"\"Cell 4: Construct Realistic Test Dataset.\n",
    "\n",
    "Mix of ImageNet, CIFAR10, and STL10 images — all processed through the CLIP\n",
    "preprocessor. N_POISON randomly-chosen images receive the DRUPE trigger.\n",
    "\"\"\"\n",
    "\n",
    "# ── Load trigger ──\n",
    "trigger_data = np.load(TRIGGER_PATH)\n",
    "trigger_patch = trigger_data[\"t\"]   # (H, W, 3) uint8\n",
    "trigger_mask = trigger_data[\"tm\"]   # (H, W, 3) float, 1 = keep original, 0 = replace with patch\n",
    "\n",
    "print(f\"Trigger patch shape: {trigger_patch.shape}, mask shape: {trigger_mask.shape}\")\n",
    "\n",
    "\n",
    "class RealisticMixedDataset(Dataset):\n",
    "    \"\"\"Mixed-source dataset with optional backdoor trigger.\n",
    "\n",
    "    Stores PIL images from multiple sources. At __getitem__ time, optionally\n",
    "    applies the DRUPE trigger (at TRIGGER_SIZE resolution) and then runs the\n",
    "    CLIP preprocessor.\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, pil_images, poison_flags, trigger_patch, trigger_mask,\n",
    "                 transform, trigger_size=224):\n",
    "        self.images = pil_images          # list[PIL.Image]\n",
    "        self.poison_flags = poison_flags  # np.ndarray[bool], len == len(images)\n",
    "        self.trigger_patch = trigger_patch\n",
    "        self.trigger_mask = trigger_mask\n",
    "        self.transform = transform\n",
    "        self.trigger_size = trigger_size\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.images)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        img = self.images[idx].copy()\n",
    "        is_poison = int(self.poison_flags[idx])\n",
    "\n",
    "        if is_poison:\n",
    "            # Resize to trigger resolution, apply trigger, convert back to PIL\n",
    "            img_np = np.array(img.resize((self.trigger_size, self.trigger_size),\n",
    "                                          Image.BILINEAR))\n",
    "            img_np = (img_np * self.trigger_mask + self.trigger_patch).astype(np.uint8)\n",
    "            img = Image.fromarray(img_np)\n",
    "\n",
    "        img_tensor = self.transform(img)\n",
    "        return img_tensor, is_poison\n",
    "\n",
    "\n",
    "# ── Collect PIL images from each source ──\n",
    "all_pil_images = []\n",
    "rng = np.random.default_rng(SEED)\n",
    "\n",
    "# 1) ImageNet train (ImageFolder — only load paths, read lazily then store PIL)\n",
    "print(f\"Loading {N_FROM_IMAGENET} images from ImageNet train...\")\n",
    "imagenet_ds = tv_datasets.ImageFolder(IMAGENET_TRAIN_DIR)\n",
    "imagenet_indices = rng.choice(len(imagenet_ds), size=N_FROM_IMAGENET, replace=False)\n",
    "for i in tqdm(imagenet_indices, desc=\"ImageNet\", leave=False):\n",
    "    path, _ = imagenet_ds.samples[i]\n",
    "    all_pil_images.append(Image.open(path).convert(\"RGB\"))\n",
    "\n",
    "# 2) CIFAR10 train (NPZ — 32×32 images)\n",
    "print(f\"Loading {N_FROM_CIFAR10} images from CIFAR10 train...\")\n",
    "cifar_data = np.load(CIFAR10_NPZ)\n",
    "cifar_x = cifar_data[\"x\"]  # (50000, 32, 32, 3)\n",
    "cifar_indices = rng.choice(len(cifar_x), size=N_FROM_CIFAR10, replace=False)\n",
    "for i in tqdm(cifar_indices, desc=\"CIFAR10\", leave=False):\n",
    "    all_pil_images.append(Image.fromarray(cifar_x[i]))\n",
    "\n",
    "# 3) STL10 train (NPZ — 96×96 images)\n",
    "print(f\"Loading {N_FROM_STL10} images from STL10 train...\")\n",
    "stl_data = np.load(STL10_NPZ)\n",
    "stl_x = stl_data[\"x\"]  # (5000, 96, 96, 3)\n",
    "n_stl_available = len(stl_x)\n",
    "if N_FROM_STL10 > n_stl_available:\n",
    "    # STL10 train only has 5000 — sample with replacement if needed\n",
    "    stl_indices = rng.choice(n_stl_available, size=N_FROM_STL10, replace=True)\n",
    "else:\n",
    "    stl_indices = rng.choice(n_stl_available, size=N_FROM_STL10, replace=False)\n",
    "for i in tqdm(stl_indices, desc=\"STL10\", leave=False):\n",
    "    all_pil_images.append(Image.fromarray(stl_x[i]))\n",
    "\n",
    "assert len(all_pil_images) == N_TOTAL, f\"Expected {N_TOTAL}, got {len(all_pil_images)}\"\n",
    "\n",
    "# ── Randomly designate N_POISON images as poisoned ──\n",
    "poison_flags = np.zeros(N_TOTAL, dtype=bool)\n",
    "poison_indices = rng.choice(N_TOTAL, size=N_POISON, replace=False)\n",
    "poison_flags[poison_indices] = True\n",
    "\n",
    "print(f\"\\nRealistic dataset: {N_TOTAL} images ({poison_flags.sum()} poisoned)\")\n",
    "print(f\"  Sources: ImageNet={N_FROM_IMAGENET}, CIFAR10={N_FROM_CIFAR10}, STL10={N_FROM_STL10}\")\n",
    "\n",
    "# ── Build dataset and loader ──\n",
    "realistic_dataset = RealisticMixedDataset(\n",
    "    pil_images=all_pil_images,\n",
    "    poison_flags=poison_flags,\n",
    "    trigger_patch=trigger_patch,\n",
    "    trigger_mask=trigger_mask,\n",
    "    transform=processor.process_image,\n",
    "    trigger_size=TRIGGER_SIZE,\n",
    ")\n",
    "realistic_loader = DataLoader(\n",
    "    realistic_dataset, batch_size=BATCH_SIZE, shuffle=False,\n",
    "    num_workers=NUM_WORKERS, pin_memory=True,\n",
    ")\n",
    "print(f\"DataLoader: {len(realistic_loader)} batches of {BATCH_SIZE}\")"
   ]
  },
